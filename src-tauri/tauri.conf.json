{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kaptur",
  "version": "0.1.0",
  "identifier": "com.kaptur.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Kaptur",
        "width": 900,
        "height": 700,
        "resizable": true,
        "decorations": true,
        "visible": false,
        "center": true,
        "focus": true
      },
      {
        "label": "overlay",
        "title": "Search",
        "width": 600,
        "height": 500,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/tesseract/**/*"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "globalShortcut": "all",
    "updater": {
      "endpoints": [
        "https://github.com/ankitpanwar070798/Kaptur/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdDNTg5Nzk4NzUyMDg0OTIKUldTU2hDQjFtSmRZZk0rVXJoMHJ5RkJrVDZvenVtbnRrTkdTMG41WG4zK2l3UWR5bXpuQVpPZVAK"
    }
  }
}
